# Crypto Squid - Hyperliquid MVP environment template
# Copy to .env and fill in required values.

# Safety and mode flags
USE_TESTNET=true
TRADING_ENABLED=true
LOG_ONLY=true
PAPER_MODE=false
ENABLE_LIVE_TRADING=false

# Account and universe
ACCOUNT_CAPITAL_USD=1000
SYMBOLS=BTC,ETH

# Coinbase credentials (required for Coinbase Advanced Trade API/WS)
COINBASE_API_KEY_NAME=
COINBASE_PRIVATE_KEY=

# Risk rules
RISK_PER_TRADE_PCT=0.50
MAX_TRADES_PER_DAY=3
MAX_CONSECUTIVE_LOSSES=2
DAILY_LOSS_LIMIT_PCT=2.0

# Entry and execution
ORDER_TIMEOUT_SECONDS=30
MAX_SLIPPAGE_BPS=10
LIMIT_OFFSET_BPS=5

# Signal thresholds
DROP_LOOKBACK_SECONDS=180
VOLUME_WINDOW_SECONDS=180
VOLUME_BASELINE_PERIODS=20
VOLUME_SPIKE_MULTIPLIER=2.0
ZSCORE_LOOKBACK_TICKS=120
ZSCORE_THRESHOLD=-2.0
STABILIZATION_WAIT_SECONDS=30
STABILIZATION_HOLD_SECONDS=30
STABILIZATION_MAX_SECONDS=180

# Symbol-specific thresholds
BTC_DROP_THRESHOLD_PCT=0.75
ETH_DROP_THRESHOLD_PCT=1.00
BTC_TP_PCT=1.0
ETH_TP_PCT=1.2
BTC_SL_PCT=0.55
ETH_SL_PCT=0.65
MAX_HOLD_MINUTES=90

# Live-only Hyperliquid credentials (keep empty unless using live mode)
HYPERLIQUID_ACCOUNT_ADDRESS=
HYPERLIQUID_SECRET_KEY=

# Metadata
STRATEGY_VERSION=hyperliquid-mvp-v1
LOG_LEVEL=INFO

# Optional memory sync
# Example: C:/Users/you/OneDrive/Documents/Obsidian Vault
OBSIDIAN_VAULT_PATH=
