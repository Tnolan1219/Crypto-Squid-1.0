[Unit]
Description=Crypto Squid Paper Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/cryptosquid
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/cryptosquid/.venv/bin/python src/bot.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
